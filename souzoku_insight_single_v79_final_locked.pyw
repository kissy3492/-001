def _home_dir() -> Path:
    base = os.environ.get("LOCALAPPDATA") or os.environ.get("APPDATA")
    if base:
        return Path(base) / "SouzokuInsightSingle"
    return Path.home() / ".souzoku_insight_single"


def _runtime_dir() -> Path:
    return _home_dir() / ("runtime_" + PAYLOAD_SHA256[:12])


def _data_dir() -> Path:
    return _home_dir() / "data"


def _log_dir() -> Path:
    return _home_dir() / "logs"


def _append_log(message: str) -> None:
    try:
        d = _log_dir()
        d.mkdir(parents=True, exist_ok=True)
        stamp = time.strftime("%Y-%m-%d %H:%M:%S")
        with (d / "launcher.log").open("a", encoding="utf-8") as f:
            f.write(f"[{stamp}] {message}\n")
    except Exception:
        pass


def _show_error(title: str, message: str) -> None:
    _append_log(title + ": " + message)
    try:
        import tkinter as tk
        from tkinter import messagebox
        root = tk.Tk()
        root.withdraw()
        messagebox.showerror(title, message)
        root.destroy()
    except Exception:
        try:
            sys.stderr.write(title + "\n" + message + "\n")
        except Exception:
            pass


def _payload_bytes() -> bytes:
    data = base64.b64decode(PAYLOAD_ZIP_B64.encode("ascii"))
    got = hashlib.sha256(data).hexdigest()
    if got != PAYLOAD_SHA256:
        raise RuntimeError("内蔵データの検証に失敗しました。SHA256=" + got)
    return data


def _safe_extract(zf: zipfile.ZipFile, dest: Path) -> None:
    dest_resolved = dest.resolve()
    for info in zf.infolist():
        name = info.filename.replace("\\", "/")
        if not name or name.startswith("/") or ".." in Path(name).parts:
            raise RuntimeError("不正な内蔵パスを検出しました: " + name)
        target = (dest / name).resolve()
        if not str(target).startswith(str(dest_resolved)):
            raise RuntimeError("展開先の検証に失敗しました: " + name)
        if info.is_dir():
            target.mkdir(parents=True, exist_ok=True)
            continue
        target.parent.mkdir(parents=True, exist_ok=True)
        with zf.open(info, "r") as src, target.open("wb") as out:
            shutil.copyfileobj(src, out)


def _extract_runtime(force: bool = False) -> Path:
    runtime = _runtime_dir()
    marker = runtime / ".payload_sha256"
    app = runtime / "tools" / "souzoku_insight_app.py"
    if not force and marker.exists() and app.exists():
        try:
            if marker.read_text(encoding="utf-8").strip() == PAYLOAD_SHA256:
                return runtime
        except Exception:
            pass
    home = _home_dir()
    home.mkdir(parents=True, exist_ok=True)
    tmp_parent = Path(tempfile.mkdtemp(prefix="souzoku_runtime_", dir=str(home)))
    try:
        import io
        with zipfile.ZipFile(io.BytesIO(_payload_bytes())) as zf:
            _safe_extract(zf, tmp_parent)
        (tmp_parent / ".payload_sha256").write_text(PAYLOAD_SHA256 + "\n", encoding="utf-8")
        if runtime.exists():
            backup = runtime.with_name(runtime.name + "_old_" + str(int(time.time())))
            try:
                runtime.rename(backup)
            except Exception:
                shutil.rmtree(runtime, ignore_errors=True)
        tmp_parent.rename(runtime)
        _append_log("runtime extracted: " + str(runtime))
        return runtime
    except Exception:
        shutil.rmtree(tmp_parent, ignore_errors=True)
        raise


def _env() -> dict:
    env = os.environ.copy()
    env.setdefault("PYTHONUTF8", "1")
    env.setdefault("PYTHONIOENCODING", "utf-8")
    env.setdefault("PYTHONDONTWRITEBYTECODE", "1")
    data = _data_dir()
    data.mkdir(parents=True, exist_ok=True)
    env["IH_APP_DATA_DIR"] = str(data)
    return env


def main() -> int:
    force = "--refresh-runtime" in sys.argv[1:]
    extract_only = "--extract-only" in sys.argv[1:]
    startup_only = "--startup-check" in sys.argv[1:]
    try:
        runtime = _extract_runtime(force=force)
    except Exception as exc:
        _show_error("相続インサイトを展開できません", str(exc))
        return 1

    app = runtime / "tools" / "souzoku_insight_app.py"
    if not app.exists():
        _show_error("相続インサイトを起動できません", "内部アプリが見つかりません: " + str(app))
        return 1

    if extract_only:
        _show_error("展開完了", "展開先: " + str(runtime))
        return 0

    py = sys.executable or "python"
    base_args = [py, str(app)]
    cwd = str(runtime / "tools")

    def run_cwd(extra: list[str], out_name: str, err_name: str) -> int:
        logs = _log_dir()
        logs.mkdir(parents=True, exist_ok=True)
        flags = getattr(subprocess, "CREATE_NO_WINDOW", 0) if os.name == "nt" else 0
        with (logs / out_name).open("w", encoding="utf-8") as out, (logs / err_name).open("w", encoding="utf-8") as err:
            return subprocess.call(base_args + extra, cwd=cwd, stdout=out, stderr=err, env=_env(), creationflags=flags)

    if startup_only:
        return run_cwd(["--startup-check", "--port", str(APP_PORT)], "startup_check.json", "startup_check_error.txt")

    check = run_cwd(["--startup-check", "--port", str(APP_PORT)], "startup_check.json", "startup_check_error.txt")
    if check != 0:
        err_path = _log_dir() / "startup_check_error.txt"
        detail = "起動前チェックに失敗しました。\nログ: " + str(err_path)
        try:
            e = err_path.read_text(encoding="utf-8", errors="ignore").strip()
            if e:
                detail += "\n\n" + e[:3000]
        except Exception:
            pass
        _show_error("相続インサイトを起動できません", detail)
        return check

    _append_log("server start")
    rc = run_cwd(["--server", "--open", "--port", str(APP_PORT)], "server.log", "server_error.log")
    if rc != 0:
        detail = "アプリが終了しました。\nログ: " + str(_log_dir())
        _show_error("相続インサイト", detail)
    return rc


if __name__ == "__main__":
    raise SystemExit(main())
